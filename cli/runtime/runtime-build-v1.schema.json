{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-bench.ai/schemas/runtime-build-v1.schema.json",
  "title": "LocalBench reproducible agentic runtime build inputs",
  "type": "object",
  "required": [
    "runtime_id",
    "builder_wsl_distro",
    "base",
    "apt_snapshot",
    "apt_packages",
    "worker_wheel_windows_path",
    "dependency_lock_windows_path",
    "dependency_lock_sha256",
    "wheelhouse_windows_path",
    "wheelhouse_sha256",
    "worker",
    "python",
    "bubblewrap",
    "appworld",
    "trust",
    "disk_requirements",
    "artifact_url",
    "provenance_url",
    "sbom_url"
  ],
  "properties": {
    "runtime_id": {"const": "aw013p1-ubuntu2404-py312-c0v1-r1"},
    "builder_wsl_distro": {"type": "string", "minLength": 1},
    "base": {"$ref": "#/$defs/download"},
    "apt_snapshot": {
      "type": "object",
      "required": ["url", "indexes_sha256"],
      "properties": {
        "url": {"type": "string", "pattern": "^https://"},
        "indexes_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "apt_packages": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[^=]+=[^=]+$"}},
    "worker_wheel_windows_path": {"type": "string", "minLength": 1},
    "dependency_lock_windows_path": {"type": "string", "minLength": 1},
    "dependency_lock_sha256": {"$ref": "#/$defs/sha256"},
    "wheelhouse_windows_path": {"type": "string", "minLength": 1},
    "wheelhouse_sha256": {"$ref": "#/$defs/sha256"},
    "worker": {"type": "object"},
    "python": {"type": "object"},
    "bubblewrap": {"type": "object"},
    "appworld": {"type": "object"},
    "trust": {"type": "object"},
    "disk_requirements": {"type": "object"},
    "artifact_url": {"type": "string", "pattern": "^https://local-bench\\.ai/"},
    "provenance_url": {"type": "string", "pattern": "^https://local-bench\\.ai/"},
    "sbom_url": {"type": "string", "pattern": "^https://local-bench\\.ai/"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "download": {
      "type": "object",
      "required": ["url", "sha256"],
      "properties": {
        "url": {"type": "string", "pattern": "^https://"},
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
